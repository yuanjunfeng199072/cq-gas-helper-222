{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IntelSubmission",
  "type": "object",
  "required": ["station_name", "submit_type"],
  "properties": {
    "station_id": { "type": "string" },
    "station_name": { "type": "string", "minLength": 1, "maxLength": 40 },
    "submit_type": { "enum": ["price", "activity", "mixed"] },
    "save_92": { "type": "string", "pattern": "^-?\\d+(\\.\\d{1,2})?$" },
    "save_95": { "type": "string", "pattern": "^-?\\d+(\\.\\d{1,2})?$" },
    "activity_schedule": { "type": "string", "maxLength": 60 },
    "activity_note": { "type": "string", "maxLength": 80 },
    "reported_at": { "type": "string", "format": "date" },
    "photo_file_id": { "type": "string" },
    "nickname": { "type": "string", "maxLength": 12 }
  }
}
